<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RMSweep.ViewModels"
        x:Class="RMSweep.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding TitleText}"
        Width="700" Height="600"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">

    <DockPanel Margin="16" LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding TitleText}"
                               FontSize="22" FontWeight="Bold" Foreground="#cdd6f4"/>
                    <TextBlock Text="{Binding PlatformInfo}"
                               FontSize="12" Foreground="#a6adc8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding LanguageLabelText}"
                               VerticalAlignment="Center" Foreground="#a6adc8" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              Width="120" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#313244" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#a6adc8" FontSize="11"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
            <Grid ColumnDefinitions="280,*">

            <!-- Left Panel: Options -->
            <Border Grid.Column="0" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,6,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Options" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding TempFilesText}"
                              IsChecked="{Binding CleanTempFiles}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding BrowserCacheText}"
                              IsChecked="{Binding CleanBrowserCache}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding RecycleBinText}"
                              IsChecked="{Binding CleanRecycleBin}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding SystemSettingsText}"
                              IsChecked="{Binding CleanSystemSettings}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding AutostartText}"
                              IsChecked="{Binding CleanAutostart}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding SystemLogsText}"
                              IsChecked="{Binding CleanSystemLogs}"
                              Foreground="#cdd6f4"/>

                    <Separator Background="#45475a" Margin="0,8"/>

                    <!-- Action Buttons -->
                    <Button Content="{Binding CleanButtonText}"
                            Command="{Binding StartCleaningCommand}"
                            IsVisible="{Binding IsNotCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="40" FontSize="14" FontWeight="SemiBold"
                            Background="#a6e3a1" Foreground="#1e1e2e"
                            CornerRadius="6"/>

                    <Button Content="{Binding CancelButtonText}"
                            Command="{Binding CancelCleaningCommand}"
                            IsVisible="{Binding IsCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="40" FontSize="14"
                            Background="#f38ba8" Foreground="#1e1e2e"
                            CornerRadius="6"/>

                    <Button Content="{Binding CreateRestorePointText}"
                            Command="{Binding CreateRestorePointCommand}"
                            IsVisible="{Binding IsNotCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="36" FontSize="12"
                            Background="#89b4fa" Foreground="#1e1e2e"
                            CornerRadius="6"/>
                </StackPanel>
            </Border>

            <!-- Right Panel: Log -->
            <Border Grid.Column="1" Background="#313244" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="{Binding LogHeaderText}"
                               FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="1" Background="#1e1e2e" CornerRadius="6" Padding="8">
                        <ListBox ItemsSource="{Binding LogEntries}"
                                 Background="Transparent"
                                 Foreground="#cdd6f4"
                                 FontSize="11"
                                 FontFamily="Consolas, Menlo, monospace">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock FontSize="11" Foreground="#a6adc8">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="[{0:HH:mm:ss}] {1} - {2}">
                                                    <Binding Path="Timestamp"/>
                                                    <Binding Path="Operation"/>
                                                    <Binding Path="Status"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Details}"
                                                   FontSize="10" Foreground="#6c7086"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <ProgressBar Grid.Row="2" Value="{Binding ProgressValue}"
                                 Maximum="100" Height="6" Margin="0,8,0,0"
                                 Foreground="#a6e3a1" Background="#45475a"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
