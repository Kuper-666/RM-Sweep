<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RMSweep.ViewModels"
        x:Class="RMSweep.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding TitleText}"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">

    <DockPanel Margin="16" LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding TitleText}"
                                   FontSize="22" FontWeight="Bold" Foreground="#cdd6f4"/>
                        <TextBlock Text="{Binding PlatformInfo}"
                                   FontSize="12" Foreground="#a6adc8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding LanguageLabelText}"
                                   VerticalAlignment="Center" Foreground="#a6adc8" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Width="120" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <!-- Disks -->
                <ItemsControl ItemsSource="{Binding Disks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#45475a" CornerRadius="6" Padding="10,6" Margin="0,0,8,0"
                                    MinWidth="180">
                                <StackPanel Spacing="2">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="#89b4fa" Text="{Binding Name}"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="#a6adc8"
                                                   Text="{Binding Label}"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding UsedPercent}" Maximum="100"
                                                 Height="6" Foreground="#f38ba8" Background="#1e1e2e"
                                                 CornerRadius="3"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" FontSize="10" Foreground="#a6adc8"
                                                   Text="{Binding FreeFormatted}"/>
                                        <TextBlock Grid.Column="1" FontSize="10" Foreground="#6c7086"
                                                   Text="{Binding UsageFormatted}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#313244" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#a6adc8" FontSize="11"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Border>

        <!-- Main Content: 3 columns -->
        <Grid ColumnDefinitions="260,*,320">

            <!-- Left Panel: Options -->
            <Border Grid.Column="0" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,6,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Options" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding TempFilesText}"
                              IsChecked="{Binding CleanTempFiles}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding BrowserCacheText}"
                              IsChecked="{Binding CleanBrowserCache}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding RecycleBinText}"
                              IsChecked="{Binding CleanRecycleBin}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding SystemSettingsText}"
                              IsChecked="{Binding CleanSystemSettings}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding AutostartText}"
                              IsChecked="{Binding CleanAutostart}"
                              Foreground="#cdd6f4"/>

                    <CheckBox Content="{Binding SystemLogsText}"
                              IsChecked="{Binding CleanSystemLogs}"
                              Foreground="#cdd6f4"/>

                    <Separator Background="#45475a" Margin="0,4"/>

                    <Button Content="{Binding CleanButtonText}"
                            Command="{Binding StartCleaningCommand}"
                            IsVisible="{Binding IsNotCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="38" FontSize="13" FontWeight="SemiBold"
                            Background="#a6e3a1" Foreground="#1e1e2e"
                            CornerRadius="6"/>

                    <Button Content="{Binding CancelButtonText}"
                            Command="{Binding CancelCleaningCommand}"
                            IsVisible="{Binding IsCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="38" FontSize="13"
                            Background="#f38ba8" Foreground="#1e1e2e"
                            CornerRadius="6"/>

                    <Button Content="{Binding CreateRestorePointText}"
                            Command="{Binding CreateRestorePointCommand}"
                            IsVisible="{Binding IsNotCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="34" FontSize="11"
                            Background="#89b4fa" Foreground="#1e1e2e"
                            CornerRadius="6"/>

                    <Separator Background="#45475a" Margin="0,4"/>

                    <Button Content="{Binding ScanButtonText}"
                            Command="{Binding ScanInstalledAppsCommand}"
                            IsVisible="{Binding IsNotCleaning}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="34" FontSize="11"
                            Background="#cba6f7" Foreground="#1e1e2e"
                            CornerRadius="6"/>
                </StackPanel>
            </Border>

            <!-- Middle Panel: Log -->
            <Border Grid.Column="1" Background="#313244" CornerRadius="8" Padding="12" Margin="6,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="{Binding LogHeaderText}"
                               FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="1" Background="#1e1e2e" CornerRadius="6" Padding="8">
                        <ListBox ItemsSource="{Binding LogEntries}"
                                 Background="Transparent"
                                 Foreground="#cdd6f4"
                                 FontSize="11"
                                 FontFamily="Consolas, Menlo, monospace">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock FontSize="11" Foreground="#a6adc8">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="[{0:HH:mm:ss}] {1} - {2}">
                                                    <Binding Path="Timestamp"/>
                                                    <Binding Path="Operation"/>
                                                    <Binding Path="Status"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Details}"
                                                   FontSize="10" Foreground="#6c7086"
                                                   TextWrapping="Wrap" Margin="16,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <ProgressBar Grid.Row="2" Value="{Binding ProgressValue}"
                                 Maximum="100" Height="6" Margin="0,8,0,0"
                                 Foreground="#a6e3a1" Background="#45475a"/>
                </Grid>
            </Border>

            <!-- Right Panel: Installed Apps -->
            <Border Grid.Column="2" Background="#313244" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding InstalledAppsHeaderText}"
                               FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="1" Background="#1e1e2e" CornerRadius="6" Padding="4">
                        <ListBox ItemsSource="{Binding InstalledApps}"
                                 Background="Transparent"
                                 Foreground="#cdd6f4"
                                 FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="2"
                                            Background="#313244" CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                            <TextBlock Grid.Column="0" Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="#cdd6f4"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Grid.Row="0"
                                                    Content="X"
                                                    Width="28" Height="28"
                                                    Background="#f38ba8" Foreground="#1e1e2e"
                                                    CornerRadius="4" FontSize="11" FontWeight="Bold"
                                                    Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).UninstallAppCommand}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                                       FontSize="10" Foreground="#a6adc8"
                                                       TextWrapping="Wrap" Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Leftovers: {0} | Hidden: {1}">
                                                        <Binding Path="Leftovers.Count"/>
                                                        <Binding Path="Leftovers.Count"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
