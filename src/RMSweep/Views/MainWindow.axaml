<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RMSweep.ViewModels"
        x:Class="RMSweep.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding TitleText}"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">

    <DockPanel Margin="16" LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding TitleText}"
                                   FontSize="22" FontWeight="Bold" Foreground="#cdd6f4"/>
                        <TextBlock Text="{Binding PlatformInfo}"
                                   FontSize="12" Foreground="#a6adc8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding LanguageLabelText}"
                                   VerticalAlignment="Center" Foreground="#a6adc8" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Width="120" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <!-- Disks -->
                <ItemsControl ItemsSource="{Binding Disks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#45475a" CornerRadius="6" Padding="10,6" Margin="0,0,8,0"
                                    MinWidth="180">
                                <StackPanel Spacing="2">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="#89b4fa" Text="{Binding Name}"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="#a6adc8"
                                                   Text="{Binding Label}"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding UsedPercent}" Maximum="100"
                                                 Height="6" Foreground="#f38ba8" Background="#1e1e2e"
                                                 CornerRadius="3"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" FontSize="10" Foreground="#a6adc8"
                                                   Text="{Binding FreeFormatted}"/>
                                        <TextBlock Grid.Column="1" FontSize="10" Foreground="#6c7086"
                                                   Text="{Binding UsageFormatted}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#313244" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#a6adc8" FontSize="11"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <ProgressBar Value="{Binding ProgressValue}" Maximum="100"
                             Height="6" Width="200" Foreground="#a6e3a1" Background="#45475a"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent"
                    FontSize="13" Padding="0">

            <!-- ========== WINDOWS TAB ========== -->
            <TabItem Header="Windows" Background="#313244">
                <Grid ColumnDefinitions="280,*,340" Margin="0,8,0,0">

                    <!-- Left: Options -->
                    <Border Grid.Column="0" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,6,0">
                        <ScrollViewer>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Windows Cleanup" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>

                                <TextBlock Text="System" FontWeight="SemiBold" FontSize="11" Foreground="#89b4fa" Margin="0,4,0,0"/>
                                <CheckBox Content="{Binding RecycleBinText}" IsChecked="{Binding CleanRecycleBin}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding TempFilesText}" IsChecked="{Binding CleanTempFiles}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding SystemLogsText}" IsChecked="{Binding CleanSystemLogs}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding DnsCacheText}" IsChecked="{Binding CleanDnsCache}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding ClipboardText}" IsChecked="{Binding CleanClipboard}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding RecentDocumentsText}" IsChecked="{Binding CleanRecentDocuments}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding ThumbnailCacheText}" IsChecked="{Binding CleanThumbnailCache}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding MemoryDumpsText}" IsChecked="{Binding CleanMemoryDumps}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding ChkdskFragmentsText}" IsChecked="{Binding CleanChkdskFragments}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding WindowsUpdateCacheText}" IsChecked="{Binding CleanWindowsUpdateCache}" Foreground="#cdd6f4" FontSize="12"/>

                                <TextBlock Text="Registry" FontWeight="SemiBold" FontSize="11" Foreground="#89b4fa" Margin="0,8,0,0"/>
                                <CheckBox Content="{Binding SystemSettingsText}" IsChecked="{Binding CleanSystemSettings}" Foreground="#cdd6f4" FontSize="12"/>
                                <CheckBox Content="{Binding AutostartText}" IsChecked="{Binding CleanAutostart}" Foreground="#cdd6f4" FontSize="12"/>

                                <Separator Background="#45475a" Margin="0,8"/>

                                <Button Content="{Binding CleanButtonText}"
                                        Command="{Binding StartCleaningCommand}"
                                        IsVisible="{Binding IsNotCleaning}"
                                        HorizontalAlignment="Stretch" Height="36" FontSize="13" FontWeight="SemiBold"
                                        Background="#a6e3a1" Foreground="#1e1e2e" CornerRadius="6"/>

                                <Button Content="{Binding CancelButtonText}"
                                        Command="{Binding CancelCleaningCommand}"
                                        IsVisible="{Binding IsCleaning}"
                                        HorizontalAlignment="Stretch" Height="36" FontSize="13"
                                        Background="#f38ba8" Foreground="#1e1e2e" CornerRadius="6"/>

                                <Button Content="{Binding CreateRestorePointText}"
                                        Command="{Binding CreateRestorePointCommand}"
                                        IsVisible="{Binding IsNotCleaning}"
                                        HorizontalAlignment="Stretch" Height="32" FontSize="11"
                                        Background="#89b4fa" Foreground="#1e1e2e" CornerRadius="6"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Middle: Log -->
                    <Border Grid.Column="1" Background="#313244" CornerRadius="8" Padding="12" Margin="6,0">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding LogHeaderText}"
                                       FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1" Background="#1e1e2e" CornerRadius="6" Padding="8">
                                <ListBox ItemsSource="{Binding LogEntries}"
                                         Background="Transparent" Foreground="#cdd6f4"
                                         FontSize="11" FontFamily="Consolas, Menlo, monospace">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <TextBlock FontSize="11" Foreground="#a6adc8">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="[{0:HH:mm:ss}] {1} - {2}">
                                                            <Binding Path="Timestamp"/>
                                                            <Binding Path="Operation"/>
                                                            <Binding Path="Status"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Details}"
                                                           FontSize="10" Foreground="#6c7086"
                                                           TextWrapping="Wrap" Margin="16,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Right: Installed Apps -->
                    <Border Grid.Column="2" Background="#313244" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding InstalledAppsHeaderText}"
                                       FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                       Margin="0,0,0,8"/>

                            <Button Grid.Row="1" Content="{Binding ScanButtonText}"
                                    Command="{Binding ScanInstalledAppsCommand}"
                                    IsVisible="{Binding IsNotCleaning}"
                                    HorizontalAlignment="Stretch" Height="30" FontSize="11"
                                    Background="#cba6f7" Foreground="#1e1e2e" CornerRadius="4"
                                    Margin="0,0,0,8"/>

                            <Border Grid.Row="2" Background="#1e1e2e" CornerRadius="6" Padding="4">
                                <ListBox ItemsSource="{Binding InstalledApps}"
                                         Background="Transparent" Foreground="#cdd6f4" FontSize="11">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8" Margin="2" Background="#313244" CornerRadius="4">
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Column="0" Grid.Row="0"
                                                               Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="#cdd6f4" TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Grid.Row="0"
                                                            Content="X" Width="28" Height="28"
                                                            Background="#f38ba8" Foreground="#1e1e2e"
                                                            CornerRadius="4" FontSize="11" FontWeight="Bold"
                                                            Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).UninstallAppCommand}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                                               FontSize="10" Foreground="#a6adc8"
                                                               TextWrapping="Wrap" Margin="0,2,0,0">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="Leftovers: {0} | Hidden: {1}">
                                                                <Binding Path="Leftovers.Count"/>
                                                                <Binding Path="Leftovers.Count"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ========== APPLICATIONS TAB ========== -->
            <TabItem Header="Applications" Background="#313244">
                <Grid ColumnDefinitions="280,*" Margin="0,8,0,0">
                    <!-- Left: Browser/App Options -->
                    <Border Grid.Column="0" Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,6,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Application Cleanup" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>

                            <TextBlock Text="Browsers" FontWeight="SemiBold" FontSize="11" Foreground="#89b4fa" Margin="0,4,0,0"/>
                            <CheckBox Content="{Binding BrowserCacheText}" IsChecked="{Binding CleanBrowserCache}" Foreground="#cdd6f4" FontSize="12"/>

                            <TextBlock Text="Other Applications" FontWeight="SemiBold" FontSize="11" Foreground="#89b4fa" Margin="0,8,0,0"/>
                            <TextBlock Text="Steam, Battle.net, Epic, Discord, Telegram" FontSize="10" Foreground="#6c7086"/>
                            <TextBlock Text="Adobe, MS Office, WinRAR" FontSize="10" Foreground="#6c7086"/>
                            <TextBlock Text="Cleared with Temporary Files option" FontSize="10" Foreground="#a6adc8"/>

                            <Separator Background="#45475a" Margin="0,12"/>

                            <Button Content="{Binding CleanButtonText}"
                                    Command="{Binding StartCleaningCommand}"
                                    IsVisible="{Binding IsNotCleaning}"
                                    HorizontalAlignment="Stretch" Height="36" FontSize="13" FontWeight="SemiBold"
                                    Background="#a6e3a1" Foreground="#1e1e2e" CornerRadius="6"/>

                            <Button Content="{Binding CancelButtonText}"
                                    Command="{Binding CancelCleaningCommand}"
                                    IsVisible="{Binding IsCleaning}"
                                    HorizontalAlignment="Stretch" Height="36" FontSize="13"
                                    Background="#f38ba8" Foreground="#1e1e2e" CornerRadius="6"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: Log -->
                    <Border Grid.Column="1" Background="#313244" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Text="{Binding LogHeaderText}"
                                       FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1" Background="#1e1e2e" CornerRadius="6" Padding="8">
                                <ListBox ItemsSource="{Binding LogEntries}"
                                         Background="Transparent" Foreground="#cdd6f4"
                                         FontSize="11" FontFamily="Consolas, Menlo, monospace">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <TextBlock FontSize="11" Foreground="#a6adc8">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="[{0:HH:mm:ss}] {1} - {2}">
                                                            <Binding Path="Timestamp"/>
                                                            <Binding Path="Operation"/>
                                                            <Binding Path="Status"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Details}"
                                                           FontSize="10" Foreground="#6c7086"
                                                           TextWrapping="Wrap" Margin="16,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ========== TOOLS TAB ========== -->
            <TabItem Header="Tools" Background="#313244">
                <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                    <!-- Left: Disk Analyzer + Duplicate Finder -->
                    <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto" Margin="0,0,6,0">
                        <!-- Disk Analyzer -->
                        <TextBlock Grid.Row="0" Text="{Binding DiskAnalyzerText}"
                                   FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                   Margin="0,0,0,8"/>

                        <Border Grid.Row="1" Background="#313244" CornerRadius="8" Padding="12">
                            <Grid RowDefinitions="Auto,Auto,Auto,*">
                                <TextBlock Grid.Row="0" Text="{Binding DirectoryLabel}" FontSize="11" Foreground="#a6adc8" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1" Text="{Binding ScanDirectoryPath}"
                                         Watermark="C:\Path\To\Scan" FontSize="12"
                                         Margin="0,0,0,8"/>

                                <Button Grid.Row="2" Content="{Binding AnalyzeButton}"
                                        Command="{Binding AnalyzeDiskSpaceCommand}"
                                        IsVisible="{Binding IsNotCleaning}"
                                        HorizontalAlignment="Stretch" Height="30" FontSize="11"
                                        Background="#89b4fa" Foreground="#1e1e2e" CornerRadius="4"
                                        Margin="0,0,0,8"/>

                                <Border Grid.Row="3" Background="#1e1e2e" CornerRadius="6" Padding="8">
                                    <ListBox ItemsSource="{Binding DiskAnalysisItems}"
                                             Background="Transparent" Foreground="#cdd6f4" FontSize="11">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                                    <TextBlock Grid.Column="0" Text="{Binding Extension}"
                                                               FontWeight="SemiBold" Foreground="#f9e2af" Width="60"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding FileCount}"
                                                               Foreground="#a6adc8" Margin="8,0"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding SizeFormatted}"
                                                               Foreground="#a6e3a1" FontWeight="SemiBold"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Border>

                        <Button Grid.Row="2" Content="{Binding ScanDuplicatesButton}"
                                Command="{Binding ScanDuplicatesCommand}"
                                IsVisible="{Binding IsNotCleaning}"
                                HorizontalAlignment="Stretch" Height="30" FontSize="11"
                                Background="#f9e2af" Foreground="#1e1e2e" CornerRadius="4"
                                Margin="0,8,0,0"/>

                        <Border Grid.Row="3" Background="#1e1e2e" CornerRadius="6" Padding="8" Margin="0,8,0,0" MaxHeight="200">
                            <ListBox ItemsSource="{Binding DuplicateGroups}"
                                     Background="Transparent" Foreground="#cdd6f4" FontSize="11">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding FileSize}"
                                                           Foreground="#f38ba8" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Count, StringFormat='{}{0} copies'}"
                                                           Foreground="#a6adc8"/>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Right: Drive Wiper + Uninstaller -->
                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="6,0,0,0">
                        <!-- Drive Wiper -->
                        <TextBlock Grid.Row="0" Text="{Binding DriveWiperText}"
                                   FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                   Margin="0,0,0,8"/>

                        <Border Grid.Row="1" Background="#313244" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="{Binding DriveLabel}" FontSize="11" Foreground="#a6adc8" VerticalAlignment="Center" Width="50"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableDrives}"
                                              SelectedItem="{Binding SelectedDriveLetter}"
                                              Width="100" FontSize="12"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="{Binding WipeMethodLabel}" FontSize="11" Foreground="#a6adc8" VerticalAlignment="Center" Width="50"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding WipeMethods}"
                                              SelectedIndex="{Binding SelectedWipeMethod}"
                                              FontSize="12"/>
                                </Grid>
                                <Button Content="{Binding WipeButton}"
                                        Command="{Binding WipeDriveCommand}"
                                        IsVisible="{Binding IsNotCleaning}"
                                        HorizontalAlignment="Stretch" Height="30" FontSize="11"
                                        Background="#f38ba8" Foreground="#1e1e2e" CornerRadius="4"/>
                            </StackPanel>
                        </Border>

                        <!-- File Shredder -->
                        <TextBlock Grid.Row="2" Text="{Binding FileShredderText}"
                                   FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                   Margin="0,16,0,8"/>

                        <Border Grid.Row="3" Background="#313244" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ShredItemPath}"
                                             Watermark="C:\Path\To\Shred" FontSize="12" Margin="0,0,8,0"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="{Binding WipeMethodLabel}" FontSize="11" Foreground="#a6adc8" VerticalAlignment="Center" Width="50"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding WipeMethods}"
                                              SelectedIndex="{Binding SelectedWipeMethod}"
                                              FontSize="12"/>
                                </Grid>
                                <Button Content="{Binding ShredButtonText}"
                                        Command="{Binding ShredItemCommand}"
                                        IsVisible="{Binding IsNotCleaning}"
                                        HorizontalAlignment="Stretch" Height="30" FontSize="11"
                                        Background="#f38ba8" Foreground="#1e1e2e" CornerRadius="4"/>
                            </StackPanel>
                        </Border>

                        <!-- Uninstaller -->
                        <TextBlock Grid.Row="4" Text="{Binding InstalledAppsHeaderText}"
                                   FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"
                                   Margin="0,16,0,8"/>

                        <Border Grid.Row="5" Background="#1e1e2e" CornerRadius="6" Padding="4">
                            <ListBox ItemsSource="{Binding InstalledApps}"
                                     Background="Transparent" Foreground="#cdd6f4" FontSize="11" MaxHeight="200">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6" Margin="1" Background="#313244" CornerRadius="3">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           TextTrimming="CharacterEllipsis" FontSize="11"/>
                                                <Button Grid.Column="1" Content="X" Width="24" Height="24"
                                                        Background="#f38ba8" Foreground="#1e1e2e"
                                                        CornerRadius="3" FontSize="10"
                                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).UninstallAppCommand}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Button Grid.Row="6" Content="{Binding ScanButtonText}"
                                Command="{Binding ScanInstalledAppsCommand}"
                                IsVisible="{Binding IsNotCleaning}"
                                HorizontalAlignment="Stretch" Height="30" FontSize="11"
                                Background="#cba6f7" Foreground="#1e1e2e" CornerRadius="4"
                                Margin="0,8,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========== SETTINGS TAB ========== -->
            <TabItem Header="Settings" Background="#313244">
                <Grid ColumnDefinitions="*" Margin="0,8,0,0">
                    <ScrollViewer>
                        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                            <!-- Exclude Paths -->
                            <Border Background="#313244" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding ExcludePathsLabel}" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>
                                    <TextBlock Text="Files and folders to skip during cleaning" FontSize="11" Foreground="#a6adc8"/>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <TextBox Grid.Column="0" Text="{Binding ExcludePathInput}"
                                                 Watermark="C:\Path\To\Exclude" FontSize="12" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="{Binding AddExcludeButton}"
                                                Command="{Binding AddExcludePathCommand}"
                                                Width="80" Height="28" FontSize="11"
                                                Background="#a6e3a1" Foreground="#1e1e2e" CornerRadius="4"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ExcludePaths}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                    <TextBlock Grid.Column="0" Text="{Binding}"
                                                               FontSize="11" Foreground="#cdd6f4"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="X"
                                                            Width="24" Height="24"
                                                            Background="#f38ba8" Foreground="#1e1e2e"
                                                            CornerRadius="3" FontSize="10"
                                                            Tag="{Binding}"
                                                            Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RemoveExcludePathCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Include Custom Folders -->
                            <Border Background="#313244" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding IncludeFoldersLabel}" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>
                                    <TextBlock Text="Additional folders to clean (e.g. game caches, temp folders)" FontSize="11" Foreground="#a6adc8"/>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <TextBox Grid.Column="0" Text="{Binding IncludeFolderInput}"
                                                 Watermark="D:\MyCacheFolder" FontSize="12" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="{Binding AddIncludeButton}"
                                                Command="{Binding AddIncludeFolderCommand}"
                                                Width="80" Height="28" FontSize="11"
                                                Background="#a6e3a1" Foreground="#1e1e2e" CornerRadius="4"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding IncludeFolders}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                    <TextBlock Grid.Column="0" Text="{Binding}"
                                                               FontSize="11" Foreground="#cdd6f4"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="X"
                                                            Width="24" Height="24"
                                                            Background="#f38ba8" Foreground="#1e1e2e"
                                                            CornerRadius="3" FontSize="10"
                                                            Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RemoveIncludeFolderCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Language -->
                            <Border Background="#313244" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding LanguageLabelText}" FontWeight="SemiBold" FontSize="14" Foreground="#cdd6f4"/>
                                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              Width="150" FontSize="12"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>